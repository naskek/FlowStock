POSTGRES_DB=flowstock
POSTGRES_USER=flowstock
POSTGRES_PASSWORD=change_me_strong
FLOWSTOCK_PORT=8080
FLOWSTOCK_HTTP_PORT=7153
FLOWSTOCK_HTTPS_PORT=7154
FLOWSTOCK_TLS_MODE=local_ca
FLOWSTOCK_TLS_SERVER_NAME=flowstock.local
FLOWSTOCK_TLS_SANS=DNS:flowstock.local
FLOWSTOCK_CA_DIR=/opt/flowstock-secrets/ca
FLOWSTOCK_SERVER_CERT_DAYS=825
FLOWSTOCK_SERVER_CERT_RENEW_BEFORE_DAYS=30
# Optional: override .NET base images when the server should use a mirror or private registry.
# FLOWSTOCK_DOTNET_SDK_IMAGE=registry.example.com/mirror/dotnet/sdk:8.0
# FLOWSTOCK_DOTNET_ASPNET_IMAGE=registry.example.com/mirror/dotnet/aspnet:8.0
BACKUP_KEEP=30
BACKUP_INTERVAL_SECONDS=86400
POSTGRES_WAIT_TIMEOUT_SECONDS=120
