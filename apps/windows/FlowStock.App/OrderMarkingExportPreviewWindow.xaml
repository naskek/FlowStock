<Window x:Class="FlowStock.App.OrderMarkingExportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Предпросмотр Excel ЧЗ"
        Height="520" Width="960"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Предпросмотр Excel ЧЗ"
                       FontSize="16"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="HeaderText"
                       Margin="0,6,0,0"
                       Foreground="#475467"
                       TextWrapping="Wrap" />
        </StackPanel>

        <DataGrid x:Name="LinesGrid"
                  Grid.Row="1"
                  Margin="0,10,0,0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*" MinWidth="220" />
                <DataGridTextColumn Header="GTIN" Binding="{Binding Gtin}" Width="150" />
                <DataGridTextColumn Header="Кол-во" Binding="{Binding QtyDisplay}" Width="90" />
                <DataGridTextColumn Header="HU" Binding="{Binding HuDisplay}" Width="80" />
                <DataGridTextColumn Header="Коды HU" Binding="{Binding HuCodesDisplay}" Width="*" MinWidth="200" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="SummaryText"
                   Grid.Row="2"
                   Margin="0,8,0,0"
                   Foreground="#475467"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Сформировать Excel" Width="150" IsDefault="True" Click="Confirm_Click" />
            <Button Content="Отмена" Width="100" IsCancel="True" Margin="8,0,0,0" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
