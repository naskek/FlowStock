<Window x:Class="FlowStock.App.ProductionPalletPlanDeleteSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Удалить паллеты из плана"
        Height="560" Width="920"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <WrapPanel Margin="0,0,0,8">
            <Button Content="Выделить доступные" Width="150" Click="SelectAvailable_Click" />
            <Button Content="Снять все" Width="120" Margin="8,0,0,0" Click="ClearAll_Click" />
        </WrapPanel>
        <TextBlock x:Name="SummaryText"
                   Grid.Row="1"
                   Margin="0,0,0,8"
                   Foreground="Gray"
                   TextWrapping="Wrap" />
        <DataGrid x:Name="PalletsGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  SelectionMode="Single">
            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock FontWeight="SemiBold"
                                       Margin="0,8,0,4"
                                       Text="{Binding Name}" />
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </DataGrid.GroupStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="44">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding IsSelectable}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="HU" Binding="{Binding HuCode}" IsReadOnly="True" Width="120" />
                <DataGridTextColumn Header="Номенклатура" Binding="{Binding ItemName}" IsReadOnly="True" Width="*" />
                <DataGridTextColumn Header="План" Binding="{Binding PlannedQtyDisplay}" IsReadOnly="True" Width="90" />
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" IsReadOnly="True" Width="100" />
                <DataGridTextColumn Header="PRD" Binding="{Binding PrdDocRef}" IsReadOnly="True" Width="150" />
                <DataGridTextColumn Header="Примечание" Binding="{Binding Note}" IsReadOnly="True" Width="260" />
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Удалить выбранные" Width="150" IsDefault="True" Click="Confirm_Click" />
            <Button Content="Отмена" Width="120" IsCancel="True" Margin="8,0,0,0" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
