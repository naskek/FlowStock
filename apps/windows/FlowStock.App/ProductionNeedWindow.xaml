<Window x:Class="FlowStock.App.ProductionNeedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Потребность производства"
        Height="620"
        Width="1180"
        MinHeight="480"
        MinWidth="960"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox x:Name="ShowAllRowsCheckBox"
                      Content="Показать все строки"
                      VerticalAlignment="Center"
                      Checked="ShowAllRowsCheckBox_Changed"
                      Unchecked="ShowAllRowsCheckBox_Changed" />
            <Button Content="Обновить"
                    Margin="12,0,0,0"
                    Padding="12,4"
                    Click="Refresh_Click" />
            <TextBlock x:Name="SummaryTextBlock"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold" />
        </StackPanel>

        <DataGrid x:Name="RowsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ItemId}" Width="80" />
                <DataGridTextColumn Header="Номенклатура" Binding="{Binding ItemName}" Width="2*" />
                <DataGridTextColumn Header="Тип" Binding="{Binding ItemTypeName}" Width="1.3*" />
                <DataGridTextColumn Header="Физ. остаток" Binding="{Binding PhysicalStockQty, StringFormat={}{0:0.###}}" Width="120" />
                <DataGridTextColumn Header="Открытый спрос" Binding="{Binding ActiveCustomerOrderOpenQty, StringFormat={}{0:0.###}}" Width="130" />
                <DataGridTextColumn Header="Резерв" Binding="{Binding ReservedCustomerOrderQty, StringFormat={}{0:0.###}}" Width="110" />
                <DataGridTextColumn Header="Свободный остаток" Binding="{Binding FreeStockQty, StringFormat={}{0:0.###}}" Width="130" />
                <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinStockQty, StringFormat={}{0:0.###}}" Width="120" />
                <DataGridTextColumn Header="Потребность" Binding="{Binding ProductionNeedQty, StringFormat={}{0:0.###}}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
