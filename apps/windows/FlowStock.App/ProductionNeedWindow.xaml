<Window x:Class="FlowStock.App.ProductionNeedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Потребность производства"
        Height="620"
        Width="1180"
        MinHeight="480"
        MinWidth="960"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Обновить"
                    Padding="12,4"
                    Click="Refresh_Click" />
            <TextBlock x:Name="SummaryTextBlock"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold" />
        </StackPanel>

        <DataGrid x:Name="RowsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Номенклатура" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2,0,2">
                                <TextBlock Text="{Binding ItemName}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Gtin}" Foreground="#667784" FontSize="11" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Остаток" Binding="{Binding StockDisplay}" Width="120" />
                <DataGridTextColumn Header="До закрытия заказов" Binding="{Binding ToCloseOrdersQty, StringFormat={}{0:0.###}}" Width="150" />
                <DataGridTextColumn Header="На склад до мин." Binding="{Binding ToMinStockQty, StringFormat={}{0:0.###}}" Width="140" />
                <DataGridTextColumn Header="Всего сформировать" Binding="{Binding TotalToMakeQty, StringFormat={}{0:0.###}}" Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
