<Window x:Class="FlowStock.App.HuReservationPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор HU"
        Height="520" Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="HeaderText" FontWeight="SemiBold" TextWrapping="Wrap" />
        <TextBlock x:Name="SummaryText" Grid.Row="1" Margin="0,6,0,8" Foreground="Gray" TextWrapping="Wrap" />
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Готово к отгрузке" Margin="0,0,0,8">
                    <ItemsControl x:Name="LedgerCandidatesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,4"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          IsEnabled="{Binding IsEnabled}"
                                          ToolTip="{Binding DisableReason}"
                                          Content="{Binding DisplayText}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>
                <GroupBox Header="Наполнено, ожидает закрытия PRD">
                    <ItemsControl x:Name="InternalCandidatesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,4"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          IsEnabled="{Binding IsEnabled}"
                                          ToolTip="{Binding DisableReason}"
                                          Content="{Binding DisplayText}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
        <TextBlock x:Name="WarningText"
                   Grid.Row="3"
                   Margin="0,8,0,0"
                   Foreground="#B42318"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="100" IsDefault="True" Click="Ok_Click" />
            <Button Content="Отмена" Width="100" IsCancel="True" Margin="8,0,0,0" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
