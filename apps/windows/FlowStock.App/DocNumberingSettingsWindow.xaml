<Window x:Class="FlowStock.App.DocNumberingSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Нумерация документов"
        Height="280"
        Width="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Шаблон" VerticalAlignment="Center" />
            <TextBox x:Name="TemplateBox"
                     Grid.Column="1"
                     ToolTip="Используйте токены {PREFIX}, {YYYY}, {SEQ}" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Год (опционально)" VerticalAlignment="Center" />
            <TextBox x:Name="YearBox" Grid.Column="1" Width="120" HorizontalAlignment="Left" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Стиль номера" VerticalAlignment="Center" />
            <ComboBox x:Name="SequenceStyleCombo"
                      Grid.Column="1"
                      Width="260"
                      HorizontalAlignment="Left"
                      DisplayMemberPath="Name" />
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="Подсказка: пустой год = год из серверного следующего номера."
                   Foreground="Gray"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сброс" MinWidth="100" Click="Reset_Click" />
            <Button Content="Сохранить" MinWidth="100" Margin="8,0,0,0" Click="Save_Click" />
            <Button Content="Закрыть" MinWidth="100" Margin="8,0,0,0" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
