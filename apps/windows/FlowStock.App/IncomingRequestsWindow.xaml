<Window x:Class="FlowStock.App.IncomingRequestsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Входящие запросы" Height="600" Width="1200">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="ApproveButton" Content="Подтвердить / Обработать" Click="Approve_Click" />
            <Button x:Name="RejectButton" Content="Отклонить" Click="Reject_Click" Margin="8,0,0,0" />
            <Button x:Name="DetailsButton" Content="Подробности..." Click="Details_Click" Margin="8,0,0,0" />
            <Button Content="Обновить" Click="Refresh_Click" Margin="8,0,0,0" />
            <Button Content="Привязка готовых HU" Click="ManualReadyHuBinding_Click" Margin="8,0,0,0" />
            <TextBlock Text="Тип:"
                       Margin="14,0,0,0"
                       VerticalAlignment="Center" />
            <ComboBox x:Name="RequestTypeFilterCombo"
                      Width="150"
                      Margin="6,0,0,0"
                      VerticalAlignment="Center"
                      SelectionChanged="RequestTypeFilterCombo_SelectionChanged" />
            <CheckBox x:Name="ShowResolvedCheck"
                      Content="Показывать обработанные"
                      Margin="14,0,0,0"
                      VerticalAlignment="Center"
                      Checked="ShowResolvedCheck_Changed"
                      Unchecked="ShowResolvedCheck_Changed" />
            <Button Content="Закрыть" Click="Close_Click" Margin="8,0,0,0" />
        </StackPanel>

        <DataGrid x:Name="RequestsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="RequestsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Создан"
                                    Binding="{Binding CreatedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}"
                                    Width="Auto" MaxWidth="170" />
                <DataGridTextColumn Header="Источник" Binding="{Binding SourceDisplay}" Width="Auto" MaxWidth="160" />
                <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="Auto" MaxWidth="230" />
                <DataGridTextColumn Header="Запрос" Binding="{Binding Summary}" Width="*" />
                <DataGridTextColumn Header="Отправитель" Binding="{Binding RequestedBy}" Width="Auto" MaxWidth="190" />
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="Auto" MaxWidth="140" />
                <DataGridTextColumn Header="Обработан"
                                    Binding="{Binding ResolvedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}"
                                    Width="Auto" MaxWidth="170" />
                <DataGridTextColumn Header="Комментарий" Binding="{Binding ResolutionNote}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
