<Window x:Class="FlowStock.App.MaintenanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Администрирование / Обслуживание"
        Height="680"
        Width="980"
        MinHeight="520"
        MinWidth="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Header="Backfill резервов заказов" Grid.Row="0">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Операция выполняется на сервере и меняет только order_receipt_plan_lines. Сначала выполните dry-run, затем введите APPLY для применения."
                           TextWrapping="Wrap" />

                <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                    <Button x:Name="DryRunButton"
                            Content="Dry-run"
                            Width="120"
                            Click="DryRun_Click" />
                    <TextBlock Text="Подтверждение apply:"
                               VerticalAlignment="Center"
                               Margin="16,0,6,0" />
                    <TextBox x:Name="ApplyConfirmBox"
                             Width="100"
                             VerticalAlignment="Center" />
                    <Button x:Name="ApplyButton"
                            Content="Apply"
                            Width="120"
                            Margin="8,0,0,0"
                            IsEnabled="False"
                            Click="Apply_Click" />
                    <TextBlock x:Name="MaintenanceStatusText"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               TextWrapping="Wrap" />
                </WrapPanel>
            </Grid>
        </GroupBox>

        <TextBox x:Name="ReportBox"
                 Grid.Row="1"
                 Margin="0,12,0,0"
                 FontFamily="Consolas"
                 FontSize="13"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 IsReadOnly="True" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Закрыть" Width="120" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
