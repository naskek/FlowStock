<Window x:Class="FlowStock.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlowStock" Height="720" Width="1100"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <DockPanel>
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Menu Grid.Column="0">
                <MenuItem Header="Справочники">
                    <MenuItem Header="Типы номенклатуры..." Click="ItemTypesMenu_Click" />
                    <MenuItem Header="Места хранения" Click="ViewLocations_Click" />
                    <MenuItem Header="Тара..." Click="TaraMenu_Click" />
                    <Separator />
                    <MenuItem Header="HU Реестр..." Click="OpenHuRegistry_Click" />
                    <Separator />
                    <MenuItem Header="Ед. измерения..." Click="UomMenu_Click" />
                    <MenuItem Header="Причины списания..." Click="WriteOffReasonsMenu_Click" />
                    <MenuItem Header="Упаковки..." Click="PackagingManager_Click" />
                </MenuItem>
                <MenuItem Header="Сервис">
                    <MenuItem Header="Входящие запросы..." Click="OpenIncomingRequests_Click" />
                    <Separator />
                    <MenuItem Header="Резервные копии..." Click="OpenBackupManager_Click" />
                    <MenuItem Header="Администрирование..." Click="OpenAdmin_Click" />
                    <MenuItem Header="Открыть папку данных" Click="OpenDataFolder_Click" />
                    <MenuItem Header="Открыть папку логов" Click="OpenLogsFolder_Click" />
                </MenuItem>
            </Menu>
            <Button Grid.Column="1" x:Name="ItemRequestsButton" Margin="6,0,6,0" Padding="8,2"
                    VerticalAlignment="Center" Click="OpenIncomingRequests_Click">
                <Grid>
                    <TextBlock Text="🔔" FontSize="14" VerticalAlignment="Center" />
                    <Border x:Name="ItemRequestsBadge" Background="#C62828" CornerRadius="8"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Padding="4,0" Margin="10,-4,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="ItemRequestsCountText" Foreground="White" FontSize="10" />
                    </Border>
                </Grid>
            </Button>
        </Grid>
        <TextBlock x:Name="LowStockIndicatorText"
                   DockPanel.Dock="Top"
                   Margin="12,0,12,6"
                   Foreground="#B71C1C"
                   FontWeight="SemiBold"
                   Visibility="Collapsed" />
        <Border Margin="12">
            <TabControl x:Name="MainTabs" SelectionChanged="MainTabs_SelectionChanged">
            <TabItem Header="Остатки">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="StatusSearchBox" Width="240" Margin="0,0,8,0" />
                        <Button Content="Поиск" Click="StatusSearch_Click" Margin="0,0,8,0" />
                        <TextBlock Text="Место хранения" VerticalAlignment="Center" Margin="12,0,6,0" />
                        <ComboBox x:Name="StockLocationFilter" Width="220" DisplayMemberPath="Name"
                                  SelectionChanged="StockLocationFilter_SelectionChanged" />
                        <TextBlock Text="HU" VerticalAlignment="Center" Margin="12,0,6,0" />
                        <ComboBox x:Name="StockHuFilter" Width="200" DisplayMemberPath="Name"
                                  SelectionChanged="StockHuFilter_SelectionChanged" />
                        <TextBlock Text="Тип" VerticalAlignment="Center" Margin="12,0,6,0" />
                        <ComboBox x:Name="StockItemTypeFilter" Width="220" DisplayMemberPath="Name"
                                  SelectionChanged="StockItemTypeFilter_SelectionChanged" />
                        <CheckBox x:Name="StockBelowMinOnlyCheckBox"
                                  Margin="12,0,0,0"
                                  VerticalAlignment="Center"
                                  Content="Только ниже минимума"
                                  Checked="StockBelowMinOnlyCheckBox_Changed"
                                  Unchecked="StockBelowMinOnlyCheckBox_Changed" />
                    </StackPanel>
                    <DataGrid x:Name="StockGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBelowMin}" Value="True">
                                        <Setter Property="Foreground" Value="#B71C1C" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Тип" Binding="{Binding ItemTypeName}" Width="Auto" MaxWidth="220" />
                            <DataGridTextColumn Header="SKU / штрихкод" Binding="{Binding Barcode}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Место хранения" Binding="{Binding LocationCode}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="HU" Binding="{Binding HuDisplay}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="В базе" Binding="{Binding BaseDisplay}" Width="Auto" MaxWidth="320" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="StockEmptyText"
                               Grid.Row="1"
                               Text="Остатки появятся после закрытия хотя бы одного документа."
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                    <Border Grid.Row="2"
                            Margin="0,8,0,0"
                            Padding="8"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="LowStockSummaryText"
                                       Margin="0,0,0,6"
                                       FontWeight="SemiBold"
                                       Foreground="#B71C1C" />
                            <DataGrid x:Name="LowStockGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Height="122"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*" />
                                    <DataGridTextColumn Header="Тип" Binding="{Binding ItemTypeName}" Width="220" />
                                    <DataGridTextColumn Header="В наличии" Binding="{Binding QtyDisplay}" Width="120" />
                                    <DataGridTextColumn Header="Минимум" Binding="{Binding MinStockQtyDisplay}" Width="120" />
                                    <DataGridTextColumn Header="Нехватка" Binding="{Binding ShortageDisplay}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Операции">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Новый документ" Click="NewDocMenu_Click" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Поиск" VerticalAlignment="Center" />
                        <TextBox x:Name="DocsSearchBox" Width="240" Margin="6,0,12,0"
                                 KeyDown="DocsSearchBox_KeyDown" />
                        <TextBlock Text="Тип" VerticalAlignment="Center" />
                        <ComboBox x:Name="DocsTypeFilter" Width="160" Margin="6,0,12,0" DisplayMemberPath="Name" />
                        <TextBlock Text="Статус" VerticalAlignment="Center" />
                        <ComboBox x:Name="DocsStatusFilter" Width="140" Margin="6,0,12,0" DisplayMemberPath="Name" />
                        <Button Content="Применить" Click="DocsApplyFilters_Click" />
                        <Button Content="Сброс" Click="DocsResetFilters_Click" Margin="8,0,0,0" />
                    </StackPanel>
                    <DataGrid x:Name="DocsGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                              MouseDoubleClick="DocsGrid_MouseDoubleClick"
                              KeyDown="DocsGrid_KeyDown">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" Binding="{Binding DocRef}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="Auto" MaxWidth="320">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="ToolTip" Value="{Binding StatusDisplay}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        <DataGridTextColumn Header="Контрагент" Binding="{Binding PartnerDisplay}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Заказ" Binding="{Binding OrderRef}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="HU" Binding="{Binding HuDisplay}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Закрыт" Binding="{Binding ClosedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="320" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Заказы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Новый" Click="OrdersNew_Click" />
                        <Button x:Name="OrdersDeleteButton" Content="Удалить" Click="OrdersDelete_Click" Margin="8,0,0,0" />
                    </StackPanel>
                    <DataGrid x:Name="OrdersGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="OrdersGrid_SelectionChanged"
                              MouseDoubleClick="OrdersGrid_MouseDoubleClick"
                              KeyDown="OrdersGrid_KeyDown">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" Binding="{Binding OrderRef}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="Auto" MaxWidth="220" />
                            <DataGridTextColumn Header="Контрагент" Binding="{Binding PartnerDisplay}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Плановая дата" Binding="{Binding DueDate, StringFormat={}{0:dd'/'MM'/'yyyy}}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Завершен" Binding="{Binding ShippedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="320" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Каталог">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Добавить" Click="AddItem_Click" TabIndex="1" />
                        <Button x:Name="ItemEditButton" Content="Редактировать" Click="EditItem_Click" Margin="8,0,0,0" TabIndex="2" />
                        <Button x:Name="ItemDeleteButton" Content="Удалить" Click="DeleteItem_Click" Margin="8,0,0,0" TabIndex="3" />
                        <Button x:Name="ItemPackagingButton" Content="Упаковки..." Margin="8,0,0,0"
                                Width="140" Click="ItemPackaging_Click" TabIndex="4" />
                        <Button Content="Импорт Excel..." Click="ImportItems_Click" Width="140" Margin="8,0,0,0" TabIndex="5" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Поиск" VerticalAlignment="Center" />
                        <TextBox x:Name="ItemsSearchBox" Width="240" Margin="6,0,12,0"
                                 KeyDown="ItemsSearchBox_KeyDown" />
                        <Button Content="Поиск" Click="ItemsSearch_Click" />
                        <Button Content="Сброс" Click="ItemsResetSearch_Click" Margin="8,0,0,0" />
                    </StackPanel>
                    <DataGrid x:Name="ItemsGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Extended" SelectionUnit="FullRow"
                              SelectionChanged="ItemsGrid_SelectionChanged"
                              MouseDoubleClick="ItemsGrid_MouseDoubleClick"
                              KeyDown="ItemsGrid_KeyDown" TabIndex="20">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" MaxWidth="120" />
                            <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="Auto" MaxWidth="320" />
                            <DataGridCheckBoxColumn Header="Активно" Binding="{Binding IsActive}" Width="Auto" MaxWidth="100" />
                            <DataGridTextColumn Header="SKU / штрихкод" Binding="{Binding Barcode}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="GTIN" Binding="{Binding Gtin}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Тип" Binding="{Binding ItemTypeName}" Width="Auto" MaxWidth="220" />
                            <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinStockQty, StringFormat={}{0:0.###}}" Width="Auto" MaxWidth="140" />
                            <DataGridTextColumn Header="Бренд" Binding="{Binding Brand}" Width="Auto" MaxWidth="240" />
                            <DataGridTextColumn Header="Объем" Binding="{Binding Volume}" Width="Auto" MaxWidth="160" />
                            <DataGridTextColumn Header="Срок годности (мес.)" Binding="{Binding ShelfLifeMonths}" Width="Auto" MaxWidth="180" />
                            <DataGridTextColumn Header="Макс. шт/HU" Binding="{Binding MaxQtyPerHu, StringFormat={}{0:0.###}}" Width="Auto" MaxWidth="160" />
                            <DataGridTextColumn Header="Тара" Binding="{Binding TaraName}" Width="Auto" MaxWidth="200" />
                            <DataGridTextColumn Header="Базовая единица" Binding="{Binding BaseUom}" Width="Auto" MaxWidth="320" />
                            <DataGridCheckBoxColumn Header="КМ" Binding="{Binding IsMarked}" Width="Auto" MaxWidth="80" Visibility="Collapsed" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Места хранения">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Добавить" Click="AddLocation_Click" TabIndex="1" />
                        <Button x:Name="LocationEditButton" Content="Редактировать" Click="EditLocation_Click" Margin="8,0,0,0" TabIndex="2" />
                        <Button x:Name="LocationDeleteButton" Content="Удалить" Click="DeleteLocation_Click" Margin="8,0,0,0" TabIndex="3" />
                    </StackPanel>
                    <DataGrid x:Name="LocationsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="LocationsGrid_SelectionChanged"
                              MouseDoubleClick="LocationsGrid_MouseDoubleClick"
                              TabIndex="20">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" MaxWidth="120" />
                            <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Макс. HU мест" Binding="{Binding MaxHuSlots}" Width="Auto" MaxWidth="180" />
                            <DataGridCheckBoxColumn Header="Авто HU" Binding="{Binding AutoHuDistributionEnabled}" Width="Auto" MaxWidth="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Контрагенты">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Добавить" Click="AddPartner_Click" TabIndex="1" />
                        <Button x:Name="PartnerEditButton" Content="Редактировать" Click="EditPartner_Click" Margin="8,0,0,0" TabIndex="2" />
                        <Button x:Name="PartnerDeleteButton" Content="Удалить" Click="DeletePartner_Click" Margin="8,0,0,0" TabIndex="3" />
                    </StackPanel>
                    <DataGrid x:Name="PartnersGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="PartnersGrid_SelectionChanged"
                              MouseDoubleClick="PartnersGrid_MouseDoubleClick"
                              TabIndex="20">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" MaxWidth="120" />
                            <DataGridTextColumn Header="ИНН" Binding="{Binding Code}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="320" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Маркировка (КМ)" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Импорт файла..." Click="KmImport_Click" />
                        <Button Content="Открыть пакет" Click="KmOpenBatch_Click" Margin="8,0,0,0" />
                        <Button Content="Редактировать" Click="KmEditBatch_Click" Margin="8,0,0,0" />
                        <Button x:Name="KmDeleteBatchButton" Content="Удалить пакет" Click="KmDeleteBatch_Click" Margin="8,0,0,0" />
                    </StackPanel>
                    <DataGrid x:Name="KmBatchesGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="KmBatchesGrid_SelectionChanged"
                              MouseDoubleClick="KmBatchesGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding ImportedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="200" />
                            <DataGridTextColumn Header="Заказ" Binding="{Binding OrderRef}" Width="Auto" MaxWidth="200" />
                            <DataGridTextColumn Header="Статус пакета" Binding="{Binding BatchStatusDisplay}" Width="Auto" MaxWidth="280" />
                            <DataGridTextColumn Header="Файл" Binding="{Binding FileName}" Width="*" />
                            <DataGridTextColumn Header="Кодов" Binding="{Binding TotalCodes}" Width="Auto" MaxWidth="120" />
                            <DataGridTextColumn Header="Ошибок" Binding="{Binding ErrorCount}" Width="Auto" MaxWidth="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            </TabControl>
        </Border>
    </DockPanel>
</Window>



