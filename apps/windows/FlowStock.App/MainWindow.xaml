<Window x:Class="FlowStock.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowStock.App"
        Title="FlowStock" Height="720" Width="1100"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <DockPanel>
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Menu Grid.Column="0">
                <MenuItem Header="Справочники">
                    <MenuItem Header="Типы номенклатуры..." Click="ItemTypesMenu_Click" />
                    <MenuItem Header="Места хранения" Click="ViewLocations_Click" />
                    <MenuItem Header="Тара..." Click="TaraMenu_Click" />
                    <Separator />
                    <MenuItem Header="HU Реестр..." Click="OpenHuRegistry_Click" />
                    <Separator />
                    <MenuItem Header="Ед. измерения..." Click="UomMenu_Click" />
                    <MenuItem Header="Причины списания..." Click="WriteOffReasonsMenu_Click" />
                    <MenuItem Header="Упаковки..." Click="PackagingManager_Click" />
                    <MenuItem Header="Нумерация документов..." Click="DocNumberingSettingsMenu_Click" />
                </MenuItem>
                <MenuItem Header="Сервис">
                    <MenuItem Header="Входящие запросы..." Click="OpenIncomingRequests_Click" />
                    <Separator />
                    <MenuItem Header="Резервные копии..." Click="OpenBackupManager_Click" />
                    <MenuItem Header="Администрирование..." Click="OpenAdmin_Click" />
                    <MenuItem Header="Открыть папку данных" Click="OpenDataFolder_Click" />
                    <MenuItem Header="Открыть папку логов" Click="OpenLogsFolder_Click" />
                </MenuItem>
                <MenuItem Header="Маркировка" Click="OpenMarking_Click" />
            </Menu>
            <Button Grid.Column="1" x:Name="ItemRequestsButton" Margin="6,0,6,0" Padding="8,2"
                    VerticalAlignment="Center" Click="OpenIncomingRequests_Click">
                <Grid>
                    <TextBlock Text="🔔" FontSize="14" VerticalAlignment="Center" />
                    <Border x:Name="ItemRequestsBadge" Background="#C62828" CornerRadius="8"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Padding="4,0" Margin="10,-4,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="ItemRequestsCountText" Foreground="White" FontSize="10" />
                    </Border>
                </Grid>
            </Button>
        </Grid>
        <TextBlock x:Name="LowStockIndicatorText"
                   DockPanel.Dock="Top"
                   Margin="12,0,12,6"
                   Foreground="#B71C1C"
                   FontWeight="SemiBold"
                   Visibility="Collapsed" />
        <Border Margin="12">
            <TabControl x:Name="MainTabs" SelectionChanged="MainTabs_SelectionChanged">
            <TabItem Header="Остатки">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <Button Content="Обновить"
                                    Padding="12,4"
                                    Click="StatusSearch_Click" />
                            <Button x:Name="ProductionNeedCreateOrdersButton"
                                    Content="Сформировать заказ"
                                    Padding="12,4"
                                    Margin="8,0,0,0"
                                    Click="ProductionNeedCreateOrders_Click" />
                            <TextBlock Text="План не входит в складской остаток"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="#666666" />
                            <TextBlock x:Name="ProductionNeedSummaryText"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <WrapPanel Grid.Row="1">
                            <TextBox x:Name="StatusSearchBox" Width="240" Margin="0,0,8,4" />
                            <Button Content="Поиск" Click="StatusSearch_Click" Margin="0,0,8,4" />
                            <TextBlock Text="Место хранения" VerticalAlignment="Center" Margin="12,0,6,4" />
                            <ComboBox x:Name="StockLocationFilter" Width="220" DisplayMemberPath="Name"
                                      Margin="0,0,0,4"
                                      SelectionChanged="StockLocationFilter_SelectionChanged" />
                            <TextBlock Text="HU" VerticalAlignment="Center" Margin="12,0,6,4" />
                            <ComboBox x:Name="StockHuFilter" Width="200" DisplayMemberPath="Name"
                                      Margin="0,0,0,4"
                                      SelectionChanged="StockHuFilter_SelectionChanged" />
                            <TextBlock Text="Тип" VerticalAlignment="Center" Margin="12,0,6,4" />
                            <ComboBox x:Name="StockItemTypeFilter" Width="220" DisplayMemberPath="Name"
                                      Margin="0,0,0,4"
                                      SelectionChanged="StockItemTypeFilter_SelectionChanged" />
                            <CheckBox x:Name="StockBelowMinOnlyCheckBox"
                                      Margin="12,0,0,4"
                                      VerticalAlignment="Center"
                                      Content="Только ниже минимума"
                                      Checked="StockBelowMinOnlyCheckBox_Changed"
                                      Unchecked="StockBelowMinOnlyCheckBox_Changed" />
                        </WrapPanel>
                    </Grid>
                    <DataGrid x:Name="StockGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" RowDetailsVisibilityMode="Collapsed"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              Visibility="Collapsed"
                              MouseDoubleClick="StockGrid_MouseDoubleClick">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="DetailsVisibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                        <Setter Property="DetailsVisibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsBelowMin}" Value="True">
                                        <Setter Property="Foreground" Value="#B71C1C" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Margin="8,4,8,8"
                                        Padding="8"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        Background="#FAFAFA"
                                        CornerRadius="4">
                                    <DataGrid AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              HeadersVisibility="Column"
                                              ItemsSource="{Binding Details}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Место хранения" Binding="{Binding LocationCode}" Width="*" />
                                            <DataGridTextColumn Header="HU" Binding="{Binding HuDisplay}" Width="220" />
                                            <DataGridTextColumn Header="В базе" Binding="{Binding BaseDisplay}" Width="140" />
                                            <DataGridTextColumn Header="Origin заказ" Binding="{Binding OriginOrderDisplay}" Width="150" />
                                            <DataGridTextColumn Header="Reserved заказ" Binding="{Binding ReservedOrderDisplay}" Width="170" />
                                            <DataGridTextColumn Header="Reserved клиент" Binding="{Binding ReservedCustomerDisplay}" Width="200" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Binding="{Binding ExpandMarker}" Width="40" />
                            <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Тип" Binding="{Binding ItemTypeName}" Width="Auto" MaxWidth="220" />
                            <DataGridTextColumn Header="SKU / штрихкод" Binding="{Binding Barcode}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="В базе" Binding="{Binding BaseDisplay}" Width="Auto" MaxWidth="320" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <DataGrid x:Name="WarehouseProductionStateGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              RowDetailsVisibilityMode="Collapsed"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              MinColumnWidth="24"
                              local:ResponsiveDataGridBehavior.IsEnabled="False"
                              MouseDoubleClick="WarehouseProductionStateGrid_MouseDoubleClick"
                              Visibility="Visible">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="4,2" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Padding" Value="4,3" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="DetailsVisibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                        <Setter Property="DetailsVisibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsBelowMin}" Value="True">
                                        <Setter Property="Foreground" Value="#B71C1C" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Margin="8,4,8,8"
                                        Padding="8"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        Background="#FAFAFA"
                                        CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="Складские HU" FontWeight="SemiBold" Margin="0,0,0,6" />
                                        <DataGrid AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  Margin="0,0,0,10"
                                                  ItemsSource="{Binding WarehouseHuRows}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="HU" Binding="{Binding HuCode}" Width="180" />
                                                <DataGridTextColumn Header="Кол-во" Binding="{Binding QtyDisplay}" Width="110" />
                                                <DataGridTextColumn Header="Статус" Binding="{Binding StockStatus}" Width="220" />
                                                <DataGridTextColumn Header="Локация" Binding="{Binding Location}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <TextBlock Text="План / производство" FontWeight="SemiBold" Margin="0,0,0,6" />
                                        <DataGrid AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  Margin="0,0,0,10"
                                                  ItemsSource="{Binding ProductionReceipts}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="HU" Binding="{Binding HuCode}" Width="150" />
                                                <DataGridTextColumn Header="Статус" Binding="{Binding PalletStatus}" Width="150" />
                                                <DataGridTextColumn Header="Кол-во" Binding="{Binding QtyDisplay}" Width="90" />
                                                <DataGridTextColumn Header="Заказ" Binding="{Binding SourceOrderRef}" Width="90" />
                                                <DataGridTextColumn Header="PRD" Binding="{Binding PrdRef}" Width="150" />
                                                <DataGridTextColumn Header="Примечание" Binding="{Binding StatusNote}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <TextBlock Text="Расчёт потребности" FontWeight="SemiBold" Margin="0,0,0,6" />
                                        <DataGrid AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  ItemsSource="{Binding NeedBreakdownRows}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Всего в заказах для клиентов" Binding="{Binding DemandToCloseDisplay}" Width="190" />
                                                <DataGridTextColumn Header="До минимума" Binding="{Binding DemandToMinDisplay}" Width="120" />
                                                <DataGridTextColumn Header="Во внутренних заказах" Binding="{Binding AlreadyPlannedInternalDisplay}" Width="150" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="26"
                                                    MinWidth="26"
                                                    MaxWidth="26"
                                                    CanUserResize="False">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ExpandMarker}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Margin="0" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Товар" Width="2*" MinWidth="240">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="4,2" />
                                        <Setter Property="VerticalContentAlignment" Value="Top" />
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Top">
                                            <TextBlock Text="{Binding ItemName}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="16"
                                                       MaxHeight="32"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ItemName}" />
                                            <TextBlock Text="{Binding ProductSubline}"
                                                       Foreground="#667784"
                                                       FontSize="11"
                                                       Margin="0,1,0,0"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ProductSubline}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="На складе"
                                                Binding="{Binding StockQtyDisplay}"
                                                Width="Auto"
                                                MinWidth="72"
                                                MaxWidth="96">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="NoWrap" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Минимум"
                                                Binding="{Binding MinStockSummary}"
                                                Width="Auto"
                                                MinWidth="80"
                                                MaxWidth="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="NoWrap" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Потребность"
                                                Binding="{Binding NeedSummary}"
                                                Width="Auto"
                                                MinWidth="92"
                                                MaxWidth="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="NoWrap" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="ToolTip" Value="{Binding NeedSummary}" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="План"
                                                Binding="{Binding PlanSummary}"
                                                Width="Auto"
                                                MinWidth="72"
                                                MaxWidth="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="NoWrap" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="ToolTip" Value="{Binding PlanSummary}" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="StockEmptyText"
                               Grid.Row="1"
                               Text="Остатки появятся после закрытия хотя бы одного документа."
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                    <Border x:Name="LowStockPanel"
                            Grid.Row="2"
                            Margin="0,8,0,0"
                             Padding="8"
                             BorderBrush="#DDD"
                             BorderThickness="1"
                             CornerRadius="4"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="LowStockSummaryText"
                                       Margin="0,0,0,6"
                                       FontWeight="SemiBold"
                                       Foreground="#B71C1C" />
                            <DataGrid x:Name="LowStockGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Height="122"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*" />
                                    <DataGridTextColumn Header="Тип" Binding="{Binding ItemTypeName}" Width="220" />
                                    <DataGridTextColumn Header="В наличии" Binding="{Binding QtyDisplay}" Width="120" />
                                    <DataGridTextColumn Header="Минимум" Binding="{Binding MinStockQtyDisplay}" Width="120" />
                                    <DataGridTextColumn Header="Нехватка" Binding="{Binding ShortageDisplay}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Потребность производства" Visibility="Collapsed">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Обновить"
                                Padding="12,4"
                                Click="ProductionNeedRefresh_Click" />
                        <Button Content="Сформировать заказ"
                                Padding="12,4"
                                Margin="8,0,0,0"
                                Click="ProductionNeedCreateOrders_Click" />
                        <TextBlock Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                    <DataGrid x:Name="ProductionNeedGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Номенклатура" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2,0,2">
                                            <TextBlock Text="{Binding ItemName}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Gtin}" Foreground="#667784" FontSize="11" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Остаток" Binding="{Binding StockDisplay}" Width="120" />
                            <DataGridTextColumn Header="До закрытия заказов" Binding="{Binding ToCloseOrdersQty, StringFormat={}{0:0.###}}" Width="150" />
                            <DataGridTextColumn Header="На склад до мин." Binding="{Binding QtyToCreate, StringFormat={}{0:0.###}}" Width="140" />
                            <DataGridTextColumn Header="Во внутренних заказах" Binding="{Binding OpenInternalOrderQty, StringFormat={}{0:0.###}}" Width="150" />
                            <DataGridTextColumn Header="Наполнено паллетами" Binding="{Binding FilledPalletDisplay}" Width="190" />
                            <DataGridTextColumn Header="Всего произвести" Binding="{Binding TotalToMakeQty, StringFormat={}{0:0.###}}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Операции">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Новый документ" Click="NewDocMenu_Click" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Поиск" VerticalAlignment="Center" />
                        <TextBox x:Name="DocsSearchBox" Width="240" Margin="6,0,12,0"
                                 KeyDown="DocsSearchBox_KeyDown" />
                        <TextBlock Text="Тип" VerticalAlignment="Center" />
                        <ComboBox x:Name="DocsTypeFilter" Width="160" Margin="6,0,12,0" DisplayMemberPath="Name" />
                        <TextBlock Text="Статус" VerticalAlignment="Center" />
                        <ComboBox x:Name="DocsStatusFilter" Width="140" Margin="6,0,12,0" DisplayMemberPath="Name" />
                        <Button Content="Применить" Click="DocsApplyFilters_Click" />
                        <Button Content="Сброс" Click="DocsResetFilters_Click" Margin="8,0,0,0" />
                    </StackPanel>
                    <DataGrid x:Name="DocsGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                              MouseDoubleClick="DocsGrid_MouseDoubleClick"
                              KeyDown="DocsGrid_KeyDown">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasProductionPalletPlan}" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD" />
                                        <Setter Property="ToolTip" Value="Паллетный выпуск по плану" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ProductionPalletFillingStarted}" Value="True">
                                        <Setter Property="Background" Value="#FFF4CC" />
                                        <Setter Property="ToolTip" Value="Наполнение начато" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" Binding="{Binding DocRef}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="Auto" MaxWidth="320">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="ToolTip" Value="{Binding StatusDisplay}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Паллеты" Binding="{Binding ProductionPalletBadge}" Width="Auto" MaxWidth="280">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8A5A00" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ProductionPalletBadge}" Value="Паллетный выпуск по плану">
                                                <Setter Property="Foreground" Value="#1565C0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        <DataGridTextColumn Header="Контрагент" Binding="{Binding PartnerDisplay}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Заказ" Binding="{Binding OrderRef}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Закрыт" Binding="{Binding ClosedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="320" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Заказы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Новый" Click="OrdersNew_Click" />
                            <Button x:Name="OrdersEditButton" Content="Изменить" Click="OrdersEdit_Click" Margin="8,0,0,0" />
                            <Button x:Name="OrdersCancelButton" Content="Отменить" Click="OrdersCancel_Click" Margin="8,0,0,0" />
                        </StackPanel>
                        <CheckBox x:Name="ShowCancelledMergedOrdersCheckBox"
                                  Content="Показать отменённые/перенесённые"
                                  Margin="0,8,0,0"
                                  Checked="ShowCancelledMergedOrdersCheckBox_Changed"
                                  Unchecked="ShowCancelledMergedOrdersCheckBox_Changed" />
                    </StackPanel>
                    <DataGrid x:Name="OrdersGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="OrdersGrid_SelectionChanged"
                              MouseDoubleClick="OrdersGrid_MouseDoubleClick"
                              KeyDown="OrdersGrid_KeyDown">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" Binding="{Binding OrderRef}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="Auto" MaxWidth="220" />
                            <DataGridTextColumn Header="Контрагент" Binding="{Binding PartnerDisplay}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Плановая дата" Binding="{Binding DueDate, StringFormat={}{0:dd'/'MM'/'yyyy}}" Width="Auto" MaxWidth="320" />
                            <DataGridTemplateColumn Header="Маркировка ЧЗ" Width="Auto" MaxWidth="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MarkingStatusShortDisplay}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MarkingStatusShortDisplay}" Value="Маркировка не проведена">
                                                            <Setter Property="Foreground" Value="#C62828" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding MarkingStatusShortDisplay}" Value="Маркировка проведена">
                                                            <Setter Property="Foreground" Value="#2E7D32" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="План паллет" Width="Auto" MaxWidth="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProductionPalletPlanShortDisplay}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#6B7280" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProductionPalletPlanShortDisplay}" Value="План не сформирован">
                                                            <Setter Property="Foreground" Value="#C2185B" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ProductionPalletPlanShortDisplay}" Value="План сформирован">
                                                            <Setter Property="Foreground" Value="#2E7D32" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ProductionPalletFillInProgress}" Value="True">
                                                            <Setter Property="Foreground" Value="#8A5A00" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ProductionPalletFillCompleted}" Value="True">
                                                            <Setter Property="Foreground" Value="#1565C0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Статус" Width="Auto" MinWidth="130" MaxWidth="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,2"
                                                CornerRadius="999"
                                                BorderThickness="1"
                                                HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FDEACC" />
                                                    <Setter Property="BorderBrush" Value="#F5B14C" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusDisplay}" Value="Готов">
                                                            <Setter Property="Background" Value="#E8F7EC" />
                                                            <Setter Property="BorderBrush" Value="#9EDDB0" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusDisplay}" Value="Выполнен">
                                                            <Setter Property="Background" Value="#1F7A3E" />
                                                            <Setter Property="BorderBrush" Value="#166330" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusDisplay}" Value="Отменён">
                                                            <Setter Property="Background" Value="#F2F4F7" />
                                                            <Setter Property="BorderBrush" Value="#98A2B3" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusDisplay}" Value="Объединён">
                                                            <Setter Property="Background" Value="#EEF2F6" />
                                                            <Setter Property="BorderBrush" Value="#98A2B3" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusDisplay}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#8A4B00" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusDisplay}" Value="Готов">
                                                                <Setter Property="Foreground" Value="#2D6A3D" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusDisplay}" Value="Выполнен">
                                                                <Setter Property="Foreground" Value="White" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusDisplay}" Value="Отменён">
                                                                <Setter Property="Foreground" Value="#475467" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusDisplay}" Value="Объединён">
                                                                <Setter Property="Foreground" Value="#475467" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Завершен" Binding="{Binding ShippedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="320" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button x:Name="LoadMoreOrdersButton"
                            Grid.Row="2"
                            Content="Загрузить следующие"
                            Click="LoadMoreOrders_Click"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Visibility="Collapsed" />
                </Grid>
            </TabItem>
            <TabItem x:Name="WarehouseTasksTab" Header="Задания">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox x:Name="WarehouseBundleFilterCombo"
                                  Width="200"
                                  SelectionChanged="WarehouseBundleFilterCombo_SelectionChanged" />
                        <Button Content="Обновить" Click="WarehouseBundlesRefresh_Click" Margin="8,0,0,0" />
                        <Button Content="Открыть" Click="WarehouseBundlesOpen_Click" Margin="8,0,0,0" />
                        <Button Content="Тест MOVE_HU" Click="WarehouseTestMove_Click" Margin="8,0,0,0" />
                        <Button Content="Тест ADOPT" Click="WarehouseTestAdopt_Click" Margin="8,0,0,0" />
                    </StackPanel>
                    <DataGrid x:Name="WarehouseBundlesGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              MouseDoubleClick="WarehouseBundlesGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding BundleRef}" Width="130" />
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="140" />
                            <DataGridTextColumn Header="Источник" Binding="{Binding Source}" Width="90" />
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="130" />
                            <DataGridTextColumn Header="Автор" Binding="{Binding CreatedBy}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Каталог">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Добавить" Click="AddItem_Click" TabIndex="1" />
                        <Button x:Name="ItemEditButton" Content="Редактировать" Click="EditItem_Click" Margin="8,0,0,0" TabIndex="2" />
                        <Button x:Name="ItemDeleteButton" Content="Удалить" Click="DeleteItem_Click" Margin="8,0,0,0" TabIndex="3" />
                        <Button x:Name="ItemPackagingButton" Content="Упаковки..." Margin="8,0,0,0"
                                Width="140" Click="ItemPackaging_Click" TabIndex="4" />
                        <Button Content="Импорт Excel..." Click="ImportItems_Click" Width="140" Margin="8,0,0,0" TabIndex="5" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Поиск" VerticalAlignment="Center" />
                        <TextBox x:Name="ItemsSearchBox" Width="240" Margin="6,0,12,0"
                                 KeyDown="ItemsSearchBox_KeyDown" />
                        <Button Content="Поиск" Click="ItemsSearch_Click" />
                        <Button Content="Сброс" Click="ItemsResetSearch_Click" Margin="8,0,0,0" />
                    </StackPanel>
                    <DataGrid x:Name="ItemsGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Extended" SelectionUnit="FullRow"
                              SelectionChanged="ItemsGrid_SelectionChanged"
                              MouseDoubleClick="ItemsGrid_MouseDoubleClick"
                              KeyDown="ItemsGrid_KeyDown" TabIndex="20">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" MaxWidth="120" />
                            <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="SKU / штрихкод" Binding="{Binding Barcode}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="GTIN" Binding="{Binding Gtin}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Тип" Binding="{Binding ItemTypeName}" Width="Auto" MaxWidth="220" />
                            <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinStockQty, StringFormat={}{0:0.###}}" Width="Auto" MaxWidth="140" />
                            <DataGridTextColumn Header="Бренд" Binding="{Binding Brand}" Width="Auto" MaxWidth="240" />
                            <DataGridTextColumn Header="Объем" Binding="{Binding Volume}" Width="Auto" MaxWidth="160" />
                            <DataGridTextColumn Header="Срок годности (мес.)" Binding="{Binding ShelfLifeMonths}" Width="Auto" MaxWidth="180" />
                            <DataGridTextColumn Header="Макс. шт/HU" Binding="{Binding MaxQtyPerHu, StringFormat={}{0:0.###}}" Width="Auto" MaxWidth="160" />
                            <DataGridTextColumn Header="Тара" Binding="{Binding TaraName}" Width="Auto" MaxWidth="200" />
                            <DataGridTextColumn Header="Базовая единица" Binding="{Binding BaseUom}" Width="Auto" MaxWidth="320" />
                            <DataGridCheckBoxColumn Header="Активно" Binding="{Binding IsActive}" Width="Auto" MaxWidth="100" />
                            <DataGridCheckBoxColumn Header="КМ" Binding="{Binding IsMarked}" Width="Auto" MaxWidth="80" Visibility="Collapsed" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Места хранения">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Добавить" Click="AddLocation_Click" TabIndex="1" />
                        <Button x:Name="LocationEditButton" Content="Редактировать" Click="EditLocation_Click" Margin="8,0,0,0" TabIndex="2" />
                        <Button x:Name="LocationDeleteButton" Content="Удалить" Click="DeleteLocation_Click" Margin="8,0,0,0" TabIndex="3" />
                    </StackPanel>
                    <DataGrid x:Name="LocationsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="LocationsGrid_SelectionChanged"
                              MouseDoubleClick="LocationsGrid_MouseDoubleClick"
                              TabIndex="20">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" MaxWidth="120" />
                            <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Макс. HU мест" Binding="{Binding MaxHuSlots}" Width="Auto" MaxWidth="180" />
                            <DataGridCheckBoxColumn Header="Авто HU" Binding="{Binding AutoHuDistributionEnabled}" Width="Auto" MaxWidth="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Контрагенты">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Добавить" Click="AddPartner_Click" TabIndex="1" />
                        <Button x:Name="PartnerEditButton" Content="Редактировать" Click="EditPartner_Click" Margin="8,0,0,0" TabIndex="2" />
                        <Button x:Name="PartnerDeleteButton" Content="Удалить" Click="DeletePartner_Click" Margin="8,0,0,0" TabIndex="3" />
                    </StackPanel>
                    <DataGrid x:Name="PartnersGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="PartnersGrid_SelectionChanged"
                              MouseDoubleClick="PartnersGrid_MouseDoubleClick"
                              TabIndex="20">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" MaxWidth="120" />
                            <DataGridTextColumn Header="ИНН" Binding="{Binding Code}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="Auto" MaxWidth="320" />
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="320" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Маркировка (КМ)" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Импорт файла..." Click="KmImport_Click" />
                        <Button Content="Открыть пакет" Click="KmOpenBatch_Click" Margin="8,0,0,0" />
                        <Button Content="Редактировать" Click="KmEditBatch_Click" Margin="8,0,0,0" />
                        <Button x:Name="KmDeleteBatchButton" Content="Удалить пакет" Click="KmDeleteBatch_Click" Margin="8,0,0,0" />
                    </StackPanel>
                    <DataGrid x:Name="KmBatchesGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="KmBatchesGrid_SelectionChanged"
                              MouseDoubleClick="KmBatchesGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding ImportedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="200" />
                            <DataGridTextColumn Header="Заказ" Binding="{Binding OrderRef}" Width="Auto" MaxWidth="200" />
                            <DataGridTextColumn Header="Статус пакета" Binding="{Binding BatchStatusDisplay}" Width="Auto" MaxWidth="280" />
                            <DataGridTextColumn Header="Файл" Binding="{Binding FileName}" Width="*" />
                            <DataGridTextColumn Header="Кодов" Binding="{Binding TotalCodes}" Width="Auto" MaxWidth="120" />
                            <DataGridTextColumn Header="Ошибок" Binding="{Binding ErrorCount}" Width="Auto" MaxWidth="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            </TabControl>
        </Border>
    </DockPanel>
</Window>



