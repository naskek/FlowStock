<Window x:Class="FlowStock.App.ItemPricesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Цены товара"
        Height="620" Width="900"
        WindowStartupLocation="CenterOwner"
        MinHeight="480" MinWidth="760">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="ItemHeaderText" Grid.Row="0" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8" />

        <GroupBox Grid.Row="1" Header="Базовая цена" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Цена *" VerticalAlignment="Center" />
                <TextBox x:Name="BasePriceBox" Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Валюта" VerticalAlignment="Center" />
                <TextBox x:Name="BaseCurrencyBox" Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" Text="RUB" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Действует с" VerticalAlignment="Center" />
                <DatePicker x:Name="BaseValidFromPicker" Grid.Row="2" Grid.Column="1" Margin="8,0,0,8" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Действует по" VerticalAlignment="Center" />
                <DatePicker x:Name="BaseValidToPicker" Grid.Row="3" Grid.Column="1" Margin="8,0,0,8" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Комментарий" VerticalAlignment="Top" Margin="0,4,0,0" />
                <TextBox x:Name="BaseCommentBox" Grid.Row="4" Grid.Column="1" Margin="8,0,0,0" Height="48"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="SaveBasePriceButton" Content="Сохранить базовую цену" Click="SaveBasePrice_Click" />
            <Button x:Name="SetOverrideButton" Content="Задать индивидуальную цену" Click="SetOverride_Click" Margin="8,0,0,0" IsEnabled="False" />
            <Button x:Name="RemoveOverrideButton" Content="Убрать индивидуальную цену" Click="RemoveOverride_Click" Margin="8,0,0,0" IsEnabled="False" />
        </StackPanel>

        <DataGrid x:Name="GroupsGrid" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionChanged="GroupsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Группа" Binding="{Binding PriceGroupName}" Width="*" MinWidth="140" />
                <DataGridTextColumn Header="Тип" Binding="{Binding PriceSourceDisplay}" Width="130" />
                <DataGridTextColumn Header="Скидка %" Binding="{Binding DefaultDiscountPercent}" Width="80" />
                <DataGridTextColumn Header="Наценка %" Binding="{Binding DefaultMarkupPercent}" Width="80" />
                <DataGridTextColumn Header="Override" Binding="{Binding OverridePriceDisplay}" Width="90" />
                <DataGridTextColumn Header="Итоговая цена" Binding="{Binding CalculatedPriceDisplay}" Width="100" />
                <DataGridTextColumn Header="Валюта" Binding="{Binding Currency}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Закрыть" Width="120" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
