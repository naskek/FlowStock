<Window x:Class="FlowStock.App.DbConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подключение к БД"
        Height="640" Width="640"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Текущее подключение" />
            <TextBlock x:Name="CurrentTargetText" FontWeight="SemiBold" />
            <TextBlock x:Name="StartupModeText"
                       Margin="0,6,0,0"
                       Foreground="DarkOrange"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />
            <TextBlock x:Name="DatabaseEnvironmentOverrideText"
                       Margin="0,6,0,0"
                       Foreground="DarkOrange"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Параметры подключения">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.ColumnSpan="2"
                                   Text="Автопоиск сканирует только этот ПК и локальные RFC1918-сети. VPN/Tailscale и внешние сети не сканируются."
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Найденные БД" VerticalAlignment="Center" />
                        <ComboBox x:Name="DiscoveredConnectionsCombo"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="8,0,0,6"
                                  DisplayMemberPath="Display"
                                  SelectionChanged="DiscoveredConnectionsCombo_SelectionChanged" />

                        <StackPanel Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,6">
                            <Button x:Name="ScanConnectionsButton"
                                    Content="Найти БД"
                                    Width="120"
                                    Click="ScanConnections_Click" />
                            <Button x:Name="ManualModeButton"
                                    Content="Ручное подключение"
                                    Width="160"
                                    Margin="8,0,0,0"
                                    Click="ManualModeButton_Click" />
                            <Button x:Name="AutoModeButton"
                                    Content="Вернуться к автопоиску"
                                    Width="180"
                                    Margin="8,0,0,0"
                                    Visibility="Collapsed"
                                    Click="AutoModeButton_Click" />
                        </StackPanel>

                        <TextBlock x:Name="DiscoveryStatusText"
                                   Grid.Row="3"
                                   Grid.ColumnSpan="2"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Host" VerticalAlignment="Center" />
                        <TextBox x:Name="HostBox" Grid.Row="4" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Port" VerticalAlignment="Center" />
                        <TextBox x:Name="PortBox" Grid.Row="5" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Database" VerticalAlignment="Center" />
                        <TextBox x:Name="DatabaseBox" Grid.Row="6" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Username" VerticalAlignment="Center" />
                        <TextBox x:Name="UsernameBox" Grid.Row="7" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Password" VerticalAlignment="Center" />
                        <PasswordBox x:Name="PasswordBox" Grid.Row="8" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Последние подключения" VerticalAlignment="Center" />
                        <ComboBox x:Name="RecentConnectionsCombo"
                                  Grid.Row="9"
                                  Grid.Column="1"
                                  Margin="8,0,0,0"
                                  DisplayMemberPath="Display"
                                  SelectionChanged="RecentConnectionsCombo_SelectionChanged" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="FlowStock Server" Margin="0,12,0,0">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                            <TextBlock x:Name="ApiWriteModeText" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock x:Name="ApiWriteCoverageText" Margin="0,4,0,0" TextWrapping="Wrap" />
                            <TextBlock x:Name="ConfigLoadedText" Margin="0,4,0,0" />
                            <TextBlock x:Name="EnvironmentOverrideText"
                                       Margin="0,6,0,0"
                                       Foreground="DarkOrange"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="Gray"
                                       Text="Для уже мигрированных write-операций WPF использует только FlowStock.Server. Прямой legacy write-path отключен."
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Server API URL" VerticalAlignment="Center" />
                        <TextBox x:Name="ServerBaseUrlBox" Grid.Row="1" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="PC URL" VerticalAlignment="Center" />
                        <TextBox x:Name="PcClientUrlBox" Grid.Row="2" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="TSD URL" VerticalAlignment="Center" />
                        <TextBox x:Name="TsdClientUrlBox" Grid.Row="3" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Device ID" VerticalAlignment="Center" />
                        <TextBox x:Name="ServerDeviceIdBox" Grid.Row="4" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Timeout (sec)" VerticalAlignment="Center" />
                        <TextBox x:Name="ServerTimeoutBox" Grid.Row="5" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="6"
                                   Grid.Column="1"
                                   Margin="8,0,0,8"
                                   Foreground="Gray"
                                   Text="Для production используйте только root-адреса без /pc, /tsd и других path-prefix."
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="TLS" VerticalAlignment="Top" />
                        <StackPanel Grid.Row="7" Grid.Column="1" Margin="8,0,0,6">
                            <CheckBox x:Name="AllowInvalidTlsCheckBox"
                                      Content="Allow invalid TLS (dev-only / unsafe)" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="DarkOrange"
                                       Text="Use only for local development with an untrusted certificate."
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Row="8"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,8,0,0">
                            <Button Content="Check server"
                                    Width="110"
                                    Click="CheckServer_Click" />
                            <Button Content="Открыть ПК"
                                    Width="110"
                                    Margin="8,0,0,0"
                                    Click="OpenPcClient_Click" />
                            <Button Content="Открыть ТСД"
                                    Width="110"
                                    Margin="8,0,0,0"
                                    Click="OpenTsdClient_Click" />
                            <Button Content="Сохранить"
                                    Width="100"
                                    Margin="8,0,0,0"
                                    Click="SaveServerSettings_Click" />
                        </StackPanel>

                        <TextBlock x:Name="ServerStatusText"
                                   Grid.Row="9"
                                   Grid.ColumnSpan="2"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CheckSchemaVersionButton"
                    Content="Проверить схему"
                    Width="150"
                    Click="CheckSchemaVersion_Click" />
            <Button x:Name="ApplyMigrationsButton"
                    Content="Инициализировать / миграции"
                    Width="190"
                    Margin="8,0,0,0"
                    Click="ApplyMigrations_Click" />
            <Button Content="Тест подключения" Width="120" Margin="8,0,0,0" Click="TestConnection_Click" />
            <Button Content="Подключиться" Width="120" Margin="8,0,0,0" Click="Save_Click" />
            <Button Content="Закрыть" Width="120" Margin="8,0,0,0" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
