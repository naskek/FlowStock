<Window x:Class="FlowStock.App.CustomerReservedHuReductionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Уменьшить резерв HU"
        Height="480" Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Выберите HU, которые останутся в заказе"
                       FontSize="16"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="HeaderText"
                       Margin="0,6,0,0"
                       Foreground="#475467"
                       TextWrapping="Wrap" />
        </StackPanel>

        <DataGrid x:Name="HuGrid"
                  Grid.Row="1"
                  Margin="0,10,0,0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Оставить" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                <DataGridTextColumn Header="HU" Binding="{Binding HuCode}" IsReadOnly="True" Width="160" />
                <DataGridTextColumn Header="Кол-во" Binding="{Binding QtyDisplay}" IsReadOnly="True" Width="90" />
                <DataGridTextColumn Header="Источник/статус" Binding="{Binding SourceStatus}" IsReadOnly="True" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="SummaryText"
                   Grid.Row="2"
                   Margin="0,8,0,0"
                   Foreground="#475467"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ConfirmButton" Content="Применить" Width="110" IsDefault="True" Click="Confirm_Click" />
            <Button Content="Отмена" Width="100" IsCancel="True" Margin="8,0,0,0" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
