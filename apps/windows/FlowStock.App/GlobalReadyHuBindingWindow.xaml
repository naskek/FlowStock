<Window x:Class="FlowStock.App.GlobalReadyHuBindingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowStock.App"
        Title="Глобальная привязка готовых HU"
        Height="720"
        Width="1220"
        MinHeight="600"
        MinWidth="1040"
        WindowStartupLocation="CenterOwner"
        Loaded="GlobalReadyHuBindingWindow_Loaded"
        Closing="GlobalReadyHuBindingWindow_Closing">
    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type local:GlobalReadyHuCandidateGroup}"
                                  ItemsSource="{Binding Candidates}">
            <TextBlock Text="{Binding ItemName}" FontWeight="SemiBold" />
        </HierarchicalDataTemplate>
        <DataTemplate DataType="{x:Type local:GlobalReadyHuCandidateItem}">
            <StackPanel Margin="0,3,0,3">
                <TextBlock Text="{Binding HuCode}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding DisplayText}" Foreground="#475467" />
            </StackPanel>
        </DataTemplate>
        <HierarchicalDataTemplate DataType="{x:Type local:GlobalReadyHuCompatibleOrderGroup}"
                                  ItemsSource="{Binding Lines}">
            <TextBlock Text="{Binding Header}" FontWeight="SemiBold" />
        </HierarchicalDataTemplate>
        <DataTemplate DataType="{x:Type local:GlobalReadyHuCompatibleLineItem}">
            <StackPanel Margin="0,3,0,3">
                <TextBlock Text="{Binding ItemName}" />
                <TextBlock Text="{Binding DisplayText}" Foreground="#475467" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="170" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="1.25*" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="Свободные HU" Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
            <TreeView x:Name="CandidatesTree"
                      Margin="8"
                      ItemsSource="{Binding CandidateGroups}"
                      SelectedItemChanged="CandidatesTree_SelectedItemChanged" />
        </GroupBox>

        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
            <Button Content="&gt;" Width="70" Height="30" Margin="0,0,0,8" Click="Bind_Click" />
            <Button Content="&lt;" Width="70" Height="30" Margin="0,0,0,18" Click="Detach_Click" />
            <Button Content="Авто" Width="70" Height="30" Click="Auto_Click" />
        </StackPanel>

        <GroupBox Header="Подходящие заказы и строки" Grid.Row="0" Grid.Column="2" Margin="10,0,0,0">
            <TreeView x:Name="CompatibleTree"
                      Margin="8"
                      ItemsSource="{Binding CompatibleOrderGroups}"
                      SelectedItemChanged="CompatibleTree_SelectedItemChanged" />
        </GroupBox>

        <GroupBox Header="Подготовленные привязки" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,12,0,0">
            <DataGrid x:Name="StagedBindingsGrid"
                      Margin="8"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      ItemsSource="{Binding StagedBindings}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="HU" Binding="{Binding HuCode}" Width="Auto" MaxWidth="160" />
                    <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*" />
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Qty, StringFormat={}{0:0.###}}" Width="Auto" MaxWidth="110" />
                    <DataGridTextColumn Header="Заказ" Binding="{Binding OrderRef}" Width="Auto" MaxWidth="150" />
                    <DataGridTextColumn Header="Клиент" Binding="{Binding PartnerDisplay}" Width="*" />
                    <DataGridTextColumn Header="Строка" Binding="{Binding OrderLineId}" Width="Auto" MaxWidth="110" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Margin="0,12,12,0"
                   VerticalAlignment="Center"
                   Foreground="#667085"
                   Text="{Binding Summary}" />
        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Обновить" Width="110" Click="Refresh_Click" />
            <Button x:Name="SaveButton" Content="Сохранить" Width="120" Margin="8,0,0,0" Click="Save_Click" />
            <Button Content="Закрыть" Width="120" Margin="8,0,0,0" IsCancel="True" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
