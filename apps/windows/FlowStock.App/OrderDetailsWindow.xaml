<Window x:Class="FlowStock.App.OrderDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказ"
        Height="700" Width="1100"
        WindowStartupLocation="CenterOwner"
        Closing="OrderDetailsWindow_Closing">
    <Window.Resources>
        <Style x:Key="OrderActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="190" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <GroupBox Header="Заказ" Grid.Row="0" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Номер" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="OrderRefBox" Grid.Row="0" Grid.Column="1" Margin="0,0,16,6" TabIndex="1" IsReadOnly="True" />
                <TextBlock Text="Тип" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox x:Name="TypeCombo" Grid.Row="0" Grid.Column="3" DisplayMemberPath="Name" Margin="0,0,0,6" TabIndex="2" />

                <TextBlock Text="Контрагент" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox x:Name="PartnerCombo" Grid.Row="1" Grid.Column="1" DisplayMemberPath="DisplayName"
                          IsEditable="True" IsTextSearchEnabled="False" TextSearch.TextPath="DisplayName"
                          StaysOpenOnEdit="True" Margin="0,0,16,6" TabIndex="3" />
                <TextBlock Text="Статус" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Border x:Name="OrderStatusBadge"
                        Grid.Row="1" Grid.Column="3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="0,0,0,6"
                        Padding="8,2"
                        CornerRadius="999"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#FDEACC" />
                            <Setter Property="BorderBrush" Value="#F5B14C" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=OrderStatusText}" Value="Готов">
                                    <Setter Property="Background" Value="#E8F7EC" />
                                    <Setter Property="BorderBrush" Value="#9EDDB0" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Text, ElementName=OrderStatusText}" Value="Выполнен">
                                    <Setter Property="Background" Value="#1F7A3E" />
                                    <Setter Property="BorderBrush" Value="#166330" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Text, ElementName=OrderStatusText}" Value="Отменён">
                                    <Setter Property="Background" Value="#F2F4F7" />
                                    <Setter Property="BorderBrush" Value="#98A2B3" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock x:Name="OrderStatusText" VerticalAlignment="Center" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#8A4B00" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=OrderStatusText}" Value="Готов">
                                        <Setter Property="Foreground" Value="#2D6A3D" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=OrderStatusText}" Value="Выполнен">
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=OrderStatusText}" Value="Отменён">
                                        <Setter Property="Foreground" Value="#475467" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <TextBlock Text="Плановая дата" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" />
                <DatePicker x:Name="DueDatePicker" Grid.Row="2" Grid.Column="1" Margin="0,0,16,6"
                            TabIndex="5" Language="en-GB" SelectedDateFormat="Short" />
                <TextBlock x:Name="OrderTypeHintText" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2"
                           VerticalAlignment="Center" Foreground="Gray" TextWrapping="Wrap" />

                <TextBlock Text="Комментарий" Grid.Row="3" Grid.Column="0" VerticalAlignment="Top" Margin="0,0,8,0" />
                <TextBox x:Name="CommentBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                         Height="60" AcceptsReturn="True" TextWrapping="Wrap" TabIndex="6" />
            </Grid>
        </GroupBox>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Row="0" Grid.Column="0" Header="Строки заказа" Margin="0,0,8,8" Padding="8">
                    <StackPanel Orientation="Vertical">
                        <Button x:Name="AddItemButton" Style="{StaticResource OrderActionButtonStyle}" Content="+ Товар" Click="AddLine_Click" TabIndex="7" />
                        <Button x:Name="EditLineButton" Style="{StaticResource OrderActionButtonStyle}" Content="Редактировать" Click="EditLine_Click" TabIndex="8" />
                        <Button x:Name="DeleteLineButton" Style="{StaticResource OrderActionButtonStyle}" Content="Удалить строку" Click="DeleteLine_Click" TabIndex="9" Margin="0" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="0" Grid.Column="1" Header="Паллетный план" Margin="8,0,0,8" Padding="8">
                    <StackPanel Orientation="Vertical">
                        <Button x:Name="PlanPalletsButton" Style="{StaticResource OrderActionButtonStyle}" Content="Сформировать план паллет" Click="PlanPallets_Click" TabIndex="10" />
                        <Button x:Name="PrintPalletLabelsButton" Style="{StaticResource OrderActionButtonStyle}" Content="Печать паллетных этикеток" Click="PrintPalletLabels_Click" TabIndex="11" />
                        <Button x:Name="DeletePalletPlanButton" Style="{StaticResource OrderActionButtonStyle}" Content="Удалить план паллет" Click="DeletePalletPlan_Click" TabIndex="12" />
                        <Button x:Name="AdoptPalletPlanButton" Style="{StaticResource OrderActionButtonStyle}" Content="Перенести план паллет" Click="AdoptPalletPlan_Click" TabIndex="13" Margin="0" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="1" Grid.Column="0" Header="Выпуск" Margin="0,0,8,0" Padding="8">
                    <Grid>
                        <Button x:Name="OpenProductionReceiptButton" Style="{StaticResource OrderActionButtonStyle}" Content="Открыть выпуск" Click="OpenProductionReceipt_Click" TabIndex="14" Margin="0" />
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Grid.Column="1" Header="Маркировка ЧЗ" Margin="8,0,0,0" Padding="8">
                    <Grid>
                        <Button x:Name="ExportMarkingButton" Style="{StaticResource OrderActionButtonStyle}" Content="Сформировать Excel ЧЗ" Click="ExportMarking_Click" TabIndex="15" Margin="0" />
                    </Grid>
                </GroupBox>
            </Grid>
            <Grid Grid.Row="1" Height="255">
                <DataGrid x:Name="OrderLinesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionChanged="OrderLinesGrid_SelectionChanged"
                          MouseDoubleClick="OrderLinesGrid_MouseDoubleClick"
                          TabIndex="10">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="ToolTip" Value="{Binding HuCoverageToolTip}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HuCoverageTone}" Value="covered">
                                    <Setter Property="Background" Value="#EAF7EE" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HuCoverageTone}" Value="missing">
                                    <Setter Property="Background" Value="#FDEEEF" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Товар" Binding="{Binding ItemName}" Width="*" IsReadOnly="True" />
                        <DataGridTextColumn Header="SKU / ШК" Binding="{Binding Barcode}" Width="150" IsReadOnly="True" />
                        <DataGridTextColumn Header="GTIN" Binding="{Binding Gtin}" Width="150" IsReadOnly="True" />
                        <DataGridTextColumn Header="Заказано (база)" Binding="{Binding QtyOrdered}" Width="140" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="HuAvailableColumn" Header="Доступно HU" Binding="{Binding AvailableHuDisplay}" Width="120" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="HuBoundColumn" Header="Привязано HU" Binding="{Binding BoundHuDisplay}" Width="130" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="HuRemainingColumn" Header="Осталось HU" Binding="{Binding RemainingHuDisplay}" Width="120" IsReadOnly="True" />
                        <DataGridTemplateColumn x:Name="HuPickerColumn" Header="HU" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding HuPickerLabel}"
                                            Padding="6,2"
                                            Click="HuPickerButton_Click"
                                            IsEnabled="{Binding IsHuPickerEnabled}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Общий HU" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsMixedPalletLine, Mode=OneWay}"
                                              Click="MixedPalletCheckBox_Click"
                                              HorizontalAlignment="Center"
                                              IsEnabled="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=Tag}"
                                              ToolTip="Строки с одинаковым номером группы HU планируются на одну микс-паллету до печати этикеток." />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Группа HU" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding MixedPalletGroupNumber, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                             Width="48"
                                             HorizontalAlignment="Center"
                                             HorizontalContentAlignment="Center"
                                             LostFocus="MixedPalletGroupTextBox_LostFocus"
                                             PreviewTextInput="MixedPalletGroupTextBox_PreviewTextInput"
                                             IsEnabled="{Binding IsMixedPalletLine}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="HU паллет" Binding="{Binding ProductionHuCodes}" Width="170" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="ProcessedQtyColumn" Header="Отгружено" Binding="{Binding QtyShipped}" Width="120" IsReadOnly="True" />
                        <DataGridTextColumn Header="Осталось" Binding="{Binding QtyRemaining}" Width="120" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="AvailableQtyColumn" Header="В наличии" Binding="{Binding QtyAvailable}" Width="120" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="CanShipNowColumn" Header="Можно отгрузить" Binding="{Binding CanShipNow}" Width="140" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="ShortageColumn" Header="Не хватает" Binding="{Binding Shortage}" Width="120" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock x:Name="OrderLinesEmptyText"
                           Text="Добавьте товары кнопкой + Товар"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"
                           IsHitTestVisible="False" />
            </Grid>
        </Grid>
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SaveStatusText" VerticalAlignment="Center" Foreground="Gray" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SaveButton" Content="Сохранить и закрыть" Width="160" Click="Save_Click" TabIndex="12" />
                <Button x:Name="CloseButton" Content="Закрыть" Width="120" IsCancel="True" Margin="8,0,0,0"
                        Click="Close_Click" TabIndex="13" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>

