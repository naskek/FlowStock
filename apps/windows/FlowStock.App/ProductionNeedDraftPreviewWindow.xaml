<Window x:Class="FlowStock.App.ProductionNeedDraftPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Предпросмотр производственного заказа"
        Height="640"
        Width="1180"
        MinHeight="560"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Будущие строки внутреннего заказа" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Text="Количество можно изменить. Строки с количеством 0 не будут созданы."
                       Margin="0,4,0,0"
                       Foreground="#475467" />
        </StackPanel>
        <DataGrid x:Name="RowsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Товар" Width="3*" MinWidth="340">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2,0,2">
                                <TextBlock Text="{Binding ItemName}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Reason}" Foreground="#667784" FontSize="11" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="GTIN" Binding="{Binding Gtin}" Width="185" MinWidth="160" IsReadOnly="True" />
                <DataGridTextColumn Header="Остаток / мин." Binding="{Binding StockSummary}" Width="150" MinWidth="130" IsReadOnly="True" />
                <DataGridTextColumn Header="Open work" Binding="{Binding WorkSummary}" Width="2*" MinWidth="240" IsReadOnly="True" />
                <DataGridTextColumn Header="Количество" Binding="{Binding QtyOrdered, StringFormat={}{0:0.###}}" Width="150" MinWidth="130" />
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Отмена"
                    Width="120"
                    Height="32"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    IsCancel="True" />
            <Button Content="Подтвердить"
                    Width="140"
                    Height="32"
                    VerticalAlignment="Center"
                    IsDefault="True"
                    Click="Confirm_Click" />
        </StackPanel>
    </Grid>
</Window>
