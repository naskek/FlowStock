<Window x:Class="FlowStock.App.WarehouseBundleDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пакет заданий"
        Height="560"
        Width="820"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="BundleTitleText" FontSize="16" FontWeight="SemiBold" />
            <TextBlock x:Name="BundleStatusText" Margin="0,4,0,0" />
            <TextBlock x:Name="BundleMetaText" Margin="0,2,0,0" Foreground="#475467" />
        </StackPanel>
        <GroupBox Grid.Row="1" Header="Действия" Margin="0,12,0,8">
            <DataGrid x:Name="LinesGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      MaxHeight="140">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding LineNo}" Width="40" />
                    <DataGridTextColumn Header="Тип" Binding="{Binding ActionType}" Width="140" />
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="90" />
                    <DataGridTextColumn Header="Описание" Binding="{Binding Summary}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <GroupBox Grid.Row="2" Header="TSD задания">
            <DataGrid x:Name="TasksGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Задание" Binding="{Binding TaskRef}" Width="120" />
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100" />
                    <DataGridTextColumn Header="HU" Binding="{Binding ExpectedHuCode}" Width="120" />
                    <DataGridTextColumn Header="События" Binding="{Binding EventsDisplay}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <GroupBox Grid.Row="3" Header="События TSD" Margin="0,8,0,0">
            <ListBox x:Name="EventsList" />
        </GroupBox>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ApproveButton" Content="Подтвердить" Width="120" Margin="0,0,8,0" Click="Approve_Click" />
            <Button x:Name="RejectButton" Content="Отклонить" Width="120" Margin="0,0,8,0" Click="Reject_Click" />
            <Button x:Name="ConfirmExecutionButton" Content="Подтвердить исполнение" Width="170" Margin="0,0,8,0" Click="ConfirmExecution_Click" />
            <Button Content="Закрыть" Width="100" IsCancel="True" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
