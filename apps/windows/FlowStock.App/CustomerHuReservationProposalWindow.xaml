<Window x:Class="FlowStock.App.CustomerHuReservationProposalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подтвердить привязку складских остатков"
        Height="640" Width="920"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Подтвердить привязку складских остатков"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="LinesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#D0D5DD"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Header}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Summary}"
                                           Foreground="#475467"
                                           Margin="0,4,0,8"
                                           TextWrapping="Wrap" />
                                <ItemsControl Grid.Row="2" ItemsSource="{Binding Candidates}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      IsEnabled="{Binding IsEnabled}"
                                                      ToolTip="{Binding DisableReason}"
                                                      Margin="0,3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="140" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding HuCode}" FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1" Text="{Binding QtyDisplay}" />
                                                    <TextBlock Grid.Column="2" Text="склад" />
                                                    <TextBlock Grid.Column="3" Text="{Binding LocationDisplay}" />
                                                    <TextBlock Grid.Column="4" Text="{Binding Note}" Foreground="#667085" TextWrapping="Wrap" />
                                                </Grid>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Grid.Row="2"
                                           Text="{Binding EmptyText}"
                                           Foreground="#667085"
                                           FontStyle="Italic"
                                           Visibility="{Binding EmptyTextVisibility}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="SummaryText"
                   Grid.Row="2"
                   Margin="0,6,0,0"
                   Foreground="#475467"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Привязать" Width="110" IsDefault="True" Click="Apply_Click" />
            <Button Content="Отмена" Width="100" IsCancel="True" Margin="8,0,0,0" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
