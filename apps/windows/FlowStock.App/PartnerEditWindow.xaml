<Window x:Class="FlowStock.App.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Контрагент"
        Height="460" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" VerticalAlignment="Center" />
        <TextBox x:Name="IdBox" Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" IsReadOnly="True" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Наименование" VerticalAlignment="Center" />
        <TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="ИНН" VerticalAlignment="Center" />
        <TextBox x:Name="InnBox" Grid.Row="2" Grid.Column="1" Margin="8,0,0,8"
                 PreviewTextInput="InnBox_PreviewTextInput"
                 DataObject.Pasting="InnBox_OnPaste" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Статус" VerticalAlignment="Center" />
        <ComboBox x:Name="StatusCombo" Grid.Row="3" Grid.Column="1" Margin="8,0,0,8" DisplayMemberPath="Name" />

        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="Коммерция" FontWeight="Bold" Margin="0,8,0,4" />
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Группа цен" VerticalAlignment="Center" />
        <ComboBox x:Name="PriceGroupCombo" Grid.Row="5" Grid.Column="1" Margin="8,0,0,8" DisplayMemberPath="Name" />

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Скидка, %" VerticalAlignment="Center" />
        <TextBox x:Name="DefaultDiscountBox" Grid.Row="6" Grid.Column="1" Margin="8,0,0,8" Text="0" />

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Оплата / доставка" VerticalAlignment="Top" Margin="0,4,0,0" />
        <StackPanel Grid.Row="7" Grid.Column="1" Margin="8,0,0,8">
            <TextBox x:Name="PaymentTermsBox" Margin="0,0,0,4" />
            <TextBox x:Name="DeliveryTermsBox" />
        </StackPanel>

        <TextBlock Grid.Row="8" Grid.Column="1"
                   Margin="8,0,0,0"
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   Text="ИНН должен быть уникальным. Пустой ИНН допускается." />

        <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,12,0,0">
            <Button Content="Сохранить" Width="120" IsDefault="True" Click="Save_Click" />
            <Button Content="Отмена" Width="120" IsCancel="True" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
