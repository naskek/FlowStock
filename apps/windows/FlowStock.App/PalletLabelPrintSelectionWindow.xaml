<Window x:Class="FlowStock.App.PalletLabelPrintSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Печать паллетных этикеток"
        Height="560" Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <WrapPanel Margin="0,0,0,8">
            <CheckBox x:Name="IncludeProductionHuCheckBox"
                      Content="Производственные HU"
                      IsChecked="True"
                      Margin="0,0,16,0"
                      Checked="CategoryCheckBox_Changed"
                      Unchecked="CategoryCheckBox_Changed" />
            <CheckBox x:Name="IncludeWarehouseHuCheckBox"
                      Content="Складские HU"
                      IsChecked="False"
                      Margin="0,0,16,0"
                      Checked="CategoryCheckBox_Changed"
                      Unchecked="CategoryCheckBox_Changed" />
            <Button Content="Выделить все" Width="120" Click="SelectAll_Click" />
            <Button Content="Снять все" Width="120" Margin="8,0,0,0" Click="ClearAll_Click" />
            <TextBlock Text="Количество копий:" Margin="16,0,4,0" VerticalAlignment="Center" />
            <TextBox x:Name="CopiesBox" Width="50" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
        </WrapPanel>
        <TextBlock x:Name="SummaryText"
                   Grid.Row="1"
                   Margin="0,0,0,8"
                   Foreground="Gray"
                   TextWrapping="Wrap" />
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GroupsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <GroupBox Margin="0,0,0,8" Header="{Binding ItemName}">
                            <ItemsControl ItemsSource="{Binding Rows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Margin="0,4"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Content="{Binding DisplayText}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Печать" Width="120" IsDefault="True" Click="Print_Click" />
            <Button Content="Отмена" Width="120" IsCancel="True" Margin="8,0,0,0" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
