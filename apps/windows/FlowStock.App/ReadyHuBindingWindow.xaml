<Window x:Class="FlowStock.App.ReadyHuBindingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowStock.App"
        Title="Привязка HU к заказу"
        Height="640"
        Width="1040"
        MinHeight="520"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Loaded="ReadyHuBindingWindow_Loaded">
    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type local:ReadyHuBindingCandidateGroup}"
                                  ItemsSource="{Binding Candidates}">
            <TextBlock Text="{Binding ItemName}" FontWeight="SemiBold" />
        </HierarchicalDataTemplate>
        <DataTemplate DataType="{x:Type local:ReadyHuBindingCandidateItem}">
            <StackPanel Margin="0,3,0,3">
                <TextBlock Text="{Binding ItemName}" />
                <TextBlock Text="{Binding DisplayText}" Foreground="#475467" />
            </StackPanel>
        </DataTemplate>
        <HierarchicalDataTemplate DataType="{x:Type local:ReadyHuBindingOrderGroup}"
                                  ItemsSource="{Binding Lines}">
            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
        </HierarchicalDataTemplate>
        <HierarchicalDataTemplate DataType="{x:Type local:ReadyHuBindingLineItem}"
                                  ItemsSource="{Binding FutureHu}">
            <StackPanel Margin="0,3,0,3">
                <TextBlock Text="{Binding Header}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Summary}" Foreground="#667085" />
            </StackPanel>
        </HierarchicalDataTemplate>
        <DataTemplate DataType="{x:Type local:ReadyHuBindingHuItem}">
            <TextBlock Text="{Binding DisplayText}" Margin="0,3,0,3" />
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="1.15*" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="Свободные HU" Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
            <TreeView x:Name="CandidatesTree"
                      Margin="8"
                      ItemsSource="{Binding CandidateGroups}"
                      SelectedItemChanged="CandidatesTree_SelectedItemChanged" />
        </GroupBox>

        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
            <Button Content="&gt;" Width="64" Height="30" Margin="0,0,0,8" Click="Bind_Click" />
            <Button Content="&lt;" Width="64" Height="30" Margin="0,0,0,18" Click="Detach_Click" />
            <Button Content="Авто" Width="64" Height="30" Click="Auto_Click" />
        </StackPanel>

        <GroupBox Header="Заказ" Grid.Row="0" Grid.Column="2" Margin="10,0,0,0">
            <TreeView x:Name="OrderTree"
                      Margin="8"
                      ItemsSource="{Binding OrderGroups}"
                      SelectedItemChanged="OrderTree_SelectedItemChanged" />
        </GroupBox>

        <TextBlock x:Name="StatusText"
                   Grid.Row="1"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Margin="0,12,12,0"
                   VerticalAlignment="Center"
                   Foreground="#667085" />
        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="SaveButton" Content="Сохранить и закрыть" Width="160" Click="Save_Click" />
            <Button Content="Закрыть" Width="120" Margin="8,0,0,0" IsCancel="True" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
